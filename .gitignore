# -----------------------------
# Büyük raster / veri dosyaları (Git LFS veya .gitignore)
# Eğer LFS kurduysan track et; kurmadıysan ignore.
# Default: ignore (LFS kurulumu opsiyonel)
# -----------------------------

# Sentinel / Landsat / ASTER ham veriler
data/ard/*.tif
data/ard/*.tiff
data/ard/*.cog.tif
data/tiles/
data/landsat/
data/landsat/*.tif
data/s1_stack/
data/s1_stack/*.tif
data/aster/
data/aster/*.hdf
data/aster/*.tif
data/change/*.tif
data/temporal/landsat_harmonized/
data/temporal/historical_pomza_overlay/
data/temporal/*.gif

# P4 layer'lar (büyük GeoTIFF'ler)
data/layers/*.tif
data/layers/*.tiff
data/layers/*.cog.tif

# P2 etiket maskeleri
data/labels/*.tif
data/labels/full_mask.tif
data/labels/ignore_mask.tif

# Generic raster + vector büyük
*.tif
*.tiff
*.cog.tif
*.hdf
*.hdf5
*.h5
*.nc
*.zarr
*.gpkg
*.gdb
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.qix

# Ama küçük doc-like dosyaları izin ver
!docs/**/*.png
!demo/fallback/*.png
!reports/**/*.png
!demo/**/*.png

# Önbellekteki WDPA / OSM raw indir dosyaları
data/wdpa_goreme.zip
data/wdpa/
data/osm_cache/


