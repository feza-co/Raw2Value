# Raw2Value AI backend environment example.
# Kaynak: MASTER_BACKEND_GELISTIRME_RAPORU_PART1.md §5.
# Üretimde gerçek değerlerle dolduran .env dosyasını .gitignore koruyor.

# ============ APP ============
APP_NAME=raw2value-ai-backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ SECURITY ============
JWT_SECRET=change-me-to-a-very-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14
PASSWORD_HASH_ROUNDS=12

# ============ DATABASE ============
DATABASE_URL=postgresql+asyncpg://raw2value:secret@db:5432/raw2value
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# ============ REDIS ============
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=20

# ============ ML PAKETI ============
ML_MODELS_DIR=/app/models
ML_DATA_DIR=/app/data
ML_WARMUP_ON_STARTUP=true
ML_RESPONSE_CACHE_TTL_SEC=300

# ============ TCMB EVDS ============
TCMB_EVDS_API_KEY=vUr0rnIjc4
TCMB_EVDS_BASE_URL=https://evds3.tcmb.gov.tr/service/evds
TCMB_FX_CACHE_TTL_SEC=300
TCMB_TIMEOUT_SEC=10
TCMB_FALLBACK_USD_TRY=45.00
TCMB_FALLBACK_EUR_TRY=52.00

# ============ OPENROUTESERVICE ============
ORS_API_KEY=eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6IjE2NjhlMjQ4OTMwNDQxNDU5YTZmY2NhNDFlMzhiZmEwIiwiaCI6Im11cm11cjY0In0=
ORS_BASE_URL=https://api.openrouteservice.org
ORS_TIMEOUT_SEC=10
ORS_DISTANCE_CACHE_TTL_SEC=3600

# ============ FILE STORAGE (MinIO) ============
S3_ENABLED=false
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=raw2value-uploads
S3_REGION=us-east-1

# ============ RATE LIMIT ============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_ANALYZE=30/minute
RATE_LIMIT_FX=60/minute
RATE_LIMIT_AUTH_LOGIN=10/minute

# ============ OBSERVABILITY ============
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
PROMETHEUS_ENABLED=true

# ============ SEED ============
SEED_DEMO_ON_STARTUP=true
DEMO_ADMIN_EMAIL=admin@raw2value.local
DEMO_ADMIN_PASSWORD=admin123
